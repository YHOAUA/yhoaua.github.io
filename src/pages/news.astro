---
import { Icon } from "astro-icon/components";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { NEWS_SOURCES } from "@/utils/news-utils";

if (!siteConfig.pages.news) {
	return Astro.redirect("/404/");
}

const title = i18n(I18nKey.news);

const localizedCategoryLabels = {
	china: i18n(I18nKey.newsCategoryChina),
	hn: i18n(I18nKey.newsCategoryHackerNews),
	news: i18n(I18nKey.newsCategoryWorldNews),
} as const;

const clientConfig = JSON.stringify({
	refreshIntervalMs: 60000,
	sources: NEWS_SOURCES.map((source) => ({
		...source,
		label: localizedCategoryLabels[source.id],
	})),
	texts: {
		empty: i18n(I18nKey.newsEmpty),
		emptyDescription: i18n(I18nKey.newsEmptyDescription),
		loading: i18n(I18nKey.pageViewsLoading),
	},
});
---

<MainGridLayout title={title}>
	<div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<div class="mb-6">
				<div class="flex items-center gap-3 mb-3">
					<div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
						<Icon name="material-symbols:newspaper" class="text-[1.5rem]" />
					</div>
					<div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
						{title}
					</div>
				</div>
			</div>

			<news-filter class="flex flex-wrap gap-2 mb-6">
				{NEWS_SOURCES.map((source) => (
					<button
						data-category={source.id}
						class:list={[
							"btn-regular px-3 py-1.5 rounded-lg transition-colors duration-200 text-sm font-medium",
							source.id === NEWS_SOURCES[0]?.id
								? "bg-(--primary) text-white hover:bg-(--primary)"
								: "bg-(--btn-regular-bg) text-(--btn-content) hover:bg-(--btn-regular-bg-hover)",
						]}
					>
						{localizedCategoryLabels[source.id]}
					</button>
				))}
			</news-filter>

			<div class="space-y-6">
				{NEWS_SOURCES.map((source) => (
					<section
						class="news-section rounded-3xl border border-(--line-divider) bg-(--card-bg) p-5 lg:p-6"
						data-category-section={source.id}
					>
						<div class="flex flex-wrap items-start justify-between gap-4 mb-5">
							<div>
								<div class="flex items-center gap-3 mb-2">
								<div class="h-11 w-11 rounded-2xl bg-(--btn-regular-bg) flex items-center justify-center text-(--primary)">
									<Icon name={source.icon} class="text-[1.5rem]" />
								</div>
								<div>
									<h2>
										<a
											href={source.homepageUrl}
											target="_blank"
											rel="noopener noreferrer"
											class="text-xl font-bold text-neutral-900 transition-colors hover:text-(--primary) dark:text-neutral-100"
										>
											{localizedCategoryLabels[source.id]}
										</a>
									</h2>
								</div>
							</div>
						</div>
						</div>

						<div
							class="space-y-2"
							data-news-list
							data-source-id={source.id}
							data-feed-url={source.feedUrl}
						>
							<div class="rounded-2xl border border-dashed border-(--line-divider) px-5 py-10 text-center text-neutral-400 dark:text-neutral-500 lg:col-span-2">
								<p>{i18n(I18nKey.pageViewsLoading)}</p>
							</div>
						</div>
					</section>
				))}
			</div>
		</div>
	</div>

	<script
		id="news-page-config"
		type="application/json"
		is:inline
		set:html={clientConfig}
	></script>

	<script slot="head" is:inline>
		const CONFIG_ELEMENT_ID = "news-page-config";
		const NEWS_STATE_KEY = "__newsPageState";

		function readNewsConfig() {
			const configElement = document.getElementById(CONFIG_ELEMENT_ID);
			if (!configElement?.textContent) return null;

			try {
				return JSON.parse(configElement.textContent);
			} catch (error) {
				console.error("[news] failed to parse config", error);
				return null;
			}
		}

		function getNewsState() {
			if (!window[NEWS_STATE_KEY]) {
				window[NEWS_STATE_KEY] = {
					timerId: null,
					inFlightPromise: null,
				};
			}

			return window[NEWS_STATE_KEY];
		}

		function cleanupNewsPolling() {
			const state = getNewsState();
			if (state.timerId) {
				window.clearInterval(state.timerId);
				state.timerId = null;
			}
		}

		function normalizeHost(url) {
			try {
				return new URL(url).hostname.replace(/^www\./, "");
			} catch {
				return "";
			}
		}

		function getTranslatedTitle(item) {
			return (
				item?._translations?.["zh-Hans"]?.title ||
				item?._translations?.["zh-Hant"]?.title ||
				item?._translations?.en?.title ||
				item?.title ||
				"Untitled"
			);
		}

		function getSummary(item, title) {
			const candidates = [item?.summary, item?.content_text];

			for (const candidate of candidates) {
				if (!candidate) continue;

				const summary = candidate
					.split("\n")
					.map((line) => line.trim())
					.find(
						(line) =>
							line &&
							line !== title &&
							!line.startsWith("👉") &&
							!line.startsWith("原文地址:") &&
							!line.startsWith("Original URL:"),
					);

				if (summary) {
					return summary;
				}
			}

			return "";
		}

		function getHeatData(item, index, total) {
			if (typeof item.score === "number") {
				return {
					value: item.score,
					label: String(item.score),
				};
			}

			const rank = index + 1;
			return {
				value: total - index,
				label: `#${rank}`,
			};
		}

		function getCommentsUrl(item, sourceId) {
			if (sourceId !== "hn") return "";

			const linkCandidates = Array.isArray(item?._links) ? item._links : [];
			const matchedLink = linkCandidates.find((entry) =>
				typeof entry?.url === "string" &&
				entry.url.includes("news.ycombinator.com/item?id="),
			);

			return matchedLink?.url || "";
		}

		function createNewsRow(item) {
			const article = document.createElement("article");
			article.className =
				"group rounded-2xl border border-(--line-divider) bg-(--main-bg) px-4 py-3.5 sm:px-5 sm:py-4 transition-all duration-300 hover:border-(--primary)";

			const row = document.createElement("div");
			row.className = "grid grid-cols-[auto_minmax(0,1fr)] items-start gap-3 sm:gap-4";

			const heat = document.createElement("div");
			heat.className =
				"min-w-13 rounded-xl bg-(--btn-regular-bg) px-2.5 py-2 text-center text-sm font-semibold text-(--primary)";
			heat.textContent = item.heatLabel;

			const content = document.createElement("div");
			content.className = "min-w-0";

			const heading = document.createElement("h3");
			heading.className =
				"min-w-0 text-[0.95rem] sm:text-[1.02rem] leading-6 font-medium text-neutral-900 dark:text-neutral-100";

			const link = document.createElement("a");
			link.href = item.url;
			link.target = "_blank";
			link.rel = "noopener noreferrer";
			link.className = "block line-clamp-2 hover:text-(--primary) transition-colors";
			link.textContent = item.title;
			heading.append(link);

			const meta = document.createElement("div");
			meta.className =
				"mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-neutral-500 dark:text-neutral-400";

			if (item.publisher) {
				const publisher = document.createElement("span");
				publisher.textContent = item.publisher;
				meta.append(publisher);
			}
			if (item.host) {
				const host = document.createElement("span");
				host.textContent = item.host;
				meta.append(host);
			}
			if (item.publishedAt) {
				const publishedAt = document.createElement("span");
				publishedAt.textContent = item.publishedAt;
				meta.append(publishedAt);
			}
			if (typeof item.comments === "number") {
				const comments = item.commentsUrl
					? document.createElement("a")
					: document.createElement("span");
				comments.textContent = `💬 ${item.comments}`;

				if (comments instanceof HTMLAnchorElement) {
					comments.href = item.commentsUrl;
					comments.target = "_blank";
					comments.rel = "noopener noreferrer";
					comments.className = "hover:text-(--primary) transition-colors";
				}

				meta.append(comments);
			}

			content.append(heading, meta);
			row.append(heat, content);
			article.append(row);

			return article;
		}

		function renderEmptyState(container, texts) {
			container.innerHTML = "";

			const empty = document.createElement("div");
			empty.className =
				"flex flex-col items-center justify-center rounded-2xl border border-dashed border-(--line-divider) py-12 text-neutral-400 dark:text-neutral-500 lg:col-span-2";

			const title = document.createElement("p");
			title.className = "text-lg";
			title.textContent = texts.empty;

			const description = document.createElement("p");
			description.className = "text-sm mt-2";
			description.textContent = texts.emptyDescription;

			empty.append(title, description);
			container.append(empty);
		}

		async function loadNewsData() {
			const config = readNewsConfig();
			if (!config) return;
			const state = getNewsState();
			if (state.inFlightPromise) {
				return state.inFlightPromise;
			}

			state.inFlightPromise = (async () => {
				await Promise.all(
					config.sources.map(async (source) => {
						const container = document.querySelector(
							`[data-news-list][data-source-id="${source.id}"]`,
						);
						const section = document.querySelector(
							`[data-category-section="${source.id}"]`,
						);

						if (!(container instanceof HTMLElement) || !(section instanceof HTMLElement)) {
							return;
						}

						try {
							const response = await fetch(source.feedUrl, {
								cache: "no-store",
							});
							if (!response.ok) {
								throw new Error(`failed: ${response.status}`);
							}

							const feed = await response.json();
							const items = (feed.items || [])
								.slice(0, 20)
								.map((item, index, allItems) => {
									const title = getTranslatedTitle(item);
									const host = normalizeHost(item.url || "");
									const heatData = getHeatData(item, index, allItems.length);

									return {
										title,
										summary: getSummary(item, title),
										url: item.url || source.homepageUrl,
										host,
										publisher: item.tags?.[0] || item.author?.name || host,
										publishedAt: item.date_published
											? new Date(item.date_published).toLocaleString()
											: "",
										score: item._score,
										comments: item._num_comments,
										commentsUrl: getCommentsUrl(item, source.id),
										heatValue: heatData.value,
										heatLabel: heatData.label,
									};
								})
								.sort((a, b) => b.heatValue - a.heatValue);

							container.innerHTML = "";

							if (items.length === 0) {
								renderEmptyState(container, config.texts);
								return;
							}

							items.forEach((item) => {
								container.append(createNewsRow(item));
							});
						} catch (error) {
							console.error(`[news] failed to fetch ${source.id}`, error);
							renderEmptyState(container, config.texts);
						}
					}),
				);
			})();

			try {
				await state.inFlightPromise;
			} finally {
				state.inFlightPromise = null;
			}
		}

		function initRefreshControls() {
			const config = readNewsConfig();
			if (!config) return;

			const state = getNewsState();
			if (state.timerId) {
				window.clearInterval(state.timerId);
			}

			state.timerId = window.setInterval(() => {
				loadNewsData();
			}, config.refreshIntervalMs);
		}

		function initNewsFilter() {
			if (customElements.get("news-filter")) return;

			class NewsFilter extends HTMLElement {
				connectedCallback() {
					this.addEventListener("click", this.handleClick);
				}

				disconnectedCallback() {
					this.removeEventListener("click", this.handleClick);
				}

				handleClick(event) {
					const target = event.target;
					const button = target instanceof Element ? target.closest("button") : null;
					if (!button) return;

					const selectedCategory = button.dataset.category;
					const buttons = this.querySelectorAll("button");
					const container = this.parentElement;
					if (!container || !selectedCategory) return;

					const sections = container.querySelectorAll("[data-category-section]");

					buttons.forEach((entry) => {
						entry.classList.remove("bg-(--primary)", "text-white");
						entry.classList.remove("hover:bg-(--primary)");
						entry.classList.add("bg-(--btn-regular-bg)", "text-(--btn-content)");
						entry.classList.add("hover:bg-(--btn-regular-bg-hover)");

						if (entry === button) {
							entry.classList.remove(
								"bg-(--btn-regular-bg)",
								"text-(--btn-content)",
							);
							entry.classList.remove("hover:bg-(--btn-regular-bg-hover)");
							entry.classList.add("bg-(--primary)", "text-white");
							entry.classList.add("hover:bg-(--primary)");
						}
					});

					sections.forEach((section) => {
						if (!(section instanceof HTMLElement)) return;
						const sectionCategory = section.dataset.categorySection;
						const shouldShow = selectedCategory === sectionCategory;

						section.style.display = shouldShow ? "" : "none";
					});
				}
			}

			customElements.define("news-filter", NewsFilter);
		}

		function initNewsPage() {
			if (!document.getElementById(CONFIG_ELEMENT_ID)) {
				cleanupNewsPolling();
				return;
			}

			initNewsFilter();
			initRefreshControls();
			const firstSection = document.querySelector("[data-category-section]");
			const sections = document.querySelectorAll("[data-category-section]");
			sections.forEach((section) => {
				if (!(section instanceof HTMLElement)) return;
				section.style.display = section === firstSection ? "" : "none";
			});
			loadNewsData();
		}

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", initNewsPage);
		} else {
			setTimeout(initNewsPage, 0);
		}

		if (typeof window !== "undefined" && window.swup) {
			window.swup.hooks.on("content:replace", () => {
				setTimeout(() => {
					if (document.getElementById(CONFIG_ELEMENT_ID)) {
						initNewsPage();
					} else {
						cleanupNewsPolling();
					}
				}, 100);
			});
		}

		window.addEventListener("pagehide", cleanupNewsPolling);
	</script>
</MainGridLayout>
