<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>一言示例</title>
    <style>
        /* 页面整体样式 */
        .body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #EAEFF5;
            margin: 0;
        }

        /* 文本容器样式 */
        #quote {
            max-width: 80%;
            font-size: 28px;
            color: #333;
            padding: 30px;
            background: rgba(255, 255, 255, 0.85); /* 半透明背景 */
            border-radius: 15px;
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2); 
            text-align: center;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease; /* 增加过渡效果 */
        }

        /* 悬停效果 */
        #quote:hover {
            transform: scale(1.05); /* 放大效果 */
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.3);
            background: rgba(255, 255, 255, 0.95);
        }

        /* 引导用户点击刷新提示 */
        #hint {
            margin-top: 10px;
            font-size: 16px;
            color: #fff;
            text-align: center;
            font-style: italic;
            opacity: 0.9;
        }
    </style>
</head>
<body>
<div class="body">
  <div id="quote" onclick="fetchQuote()">点击这里获取一句话</div>

<script>
    async function fetchQuote() {
        try {
            const response = await fetch('https://v1.hitokoto.cn/?c=i');
            const data = await response.json();
            document.getElementById('quote').innerText = data.hitokoto;
        } catch (error) {
            console.error('获取失败:', error);
            document.getElementById('quote').innerText = '无法获取一言，请重试。';
        }
    }


    // 页面加载时自动获取一句话
    window.onload = fetchQuote;
</script>
</div>


</body>
</html>
