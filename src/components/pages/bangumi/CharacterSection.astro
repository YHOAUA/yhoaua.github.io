---
import ClientPagination from "@/components/common/ClientPagination.astro";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import type { CharacterProfile } from "@/types/character";
import CharacterCard from "./CharacterCard.astro";
import FilterControls from "./FilterControls.astro";

interface Props {
	sectionId: string;
	items: CharacterProfile[];
	isActive: boolean;
	itemsPerPage?: number;
}

const { sectionId, items, isActive, itemsPerPage = 12 } = Astro.props;

const roleCounts = items.reduce(
	(acc, item) => {
		for (const role of item.roles) {
			acc[role] = (acc[role] || 0) + 1;
		}
		return acc;
	},
	{} as Record<string, number>,
);

const filters = [
	{ value: "all", label: i18n(I18nKey.bangumiFilterAll), count: items.length },
	...Object.entries(roleCounts)
		.sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], "zh-CN"))
		.map(([role, count]) => ({
			value: role,
			label: role,
			count,
		})),
];
---

<div class:list={["bangumi-section", { "hidden": !isActive }]} data-section={sectionId}>
	{items.length > 0 ? (
		<>
			<FilterControls
				filters={filters}
				activeFilter="all"
				sectionId={sectionId}
			/>

			<div class="bangumi-masonry" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem;">
				{items.map((item, index) => (
					<div
						class="bangumi-item"
						data-item-section={sectionId}
						data-item-filters={JSON.stringify(item.roles)}
						style={index < itemsPerPage ? undefined : "display: none;"}
					>
						<CharacterCard character={item} />
					</div>
				))}
			</div>

			<ClientPagination
				totalItems={items.length}
				itemsPerPage={itemsPerPage}
				currentPage={1}
				sectionId={sectionId}
			/>
		</>
	) : (
		<div class="py-12 text-center">
			<h3 class="mb-2 text-xl font-medium text-gray-600 dark:text-gray-400">{i18n(I18nKey.bangumiNoData)}</h3>
			<p class="text-gray-500 dark:text-gray-500">{i18n(I18nKey.bangumiNoDataDescription)}</p>
		</div>
	)}
</div>

<style is:global>
	@media (min-width: 640px) {
		.bangumi-masonry {
			grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)) !important;
		}
	}
</style>
